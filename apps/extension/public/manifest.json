{
  "manifest_version": 3,
  "name": "Bidly - Job Application Tracker",
  "description": "Track job applications directly from job listing pages",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_icon": {
      "32": "icon-32.png"
    }
  },
  "icons": {
    "32": "icon-32.png",
    "128": "icon-128.png"
  }
}
