{
  "name": "bidly-app",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server dev",
    "dev:extension": "pnpm --filter extension dev",
    "build": "turbo build",
    "build:web": "pnpm --filter web build",
    "build:server": "pnpm --filter server build",
    "build:extension": "pnpm --filter extension build",
    "build:shared": "pnpm --filter @bidly/shared build",
    "lint": "turbo lint",
    "start": "turbo start --filter=web --filter=server",
    "start:web": "pnpm --filter web start",
    "start:server": "pnpm --filter server start"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@9.15.0"
}
